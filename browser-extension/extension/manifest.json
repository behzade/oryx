{
  "manifest_version": 3,
  "name": "Oryx URL Opener",
  "description": "Send the current tab or selected link to Oryx.",
  "version": "0.1.0",
  "key": "",
  "minimum_chrome_version": "102",
  "permissions": [
    "activeTab",
    "contextMenus",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open in Oryx",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
