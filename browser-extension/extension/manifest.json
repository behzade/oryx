{
  "manifest_version": 3,
  "name": "Oryx URL Opener",
  "description": "Send the current tab or selected link to Oryx.",
  "version": "0.1.0",
  "minimum_chrome_version": "102",
  "permissions": [
    "activeTab",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open in Oryx"
  }
}
